# EditorConfig — 跨编辑器一致性配置
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,ts,jsx,tsx,mjs,cjs,vue,svelte}]
indent_size = 2

[*.{css,scss,less,sass}]
indent_size = 2

[*.{html,htm,xml,svg}]
indent_size = 2

[*.{json,yaml,yml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab

[*.{sh,bash,zsh}]
indent_size = 2
