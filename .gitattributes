# ========================================
# 跨平台行尾一致性配置
# 确保Windows/Linux/macOS协作时不产生diff噪音
# ========================================

# 默认行为：文本文件自动归一化为 LF
*        text=auto

# ----------------------------------------
# 强制 LF（这些文件必须用 LF）
# ----------------------------------------
*.sh     text eol=lf
*.bash   text eol=lf
*.zsh    text eol=lf

*.js     text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.jsx    text eol=lf
*.vue    text eol=lf
*.svelte text eol=lf

*.css    text eol=lf
*.scss   text eol=lf
*.less   text eol=lf
*.sass   text eol=lf

*.html   text eol=lf
*.htm    text eol=lf
*.xml    text eol=lf
*.svg    text eol=lf

*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.toml   text eol=lf

*.md     text eol=lf
*.txt    text eol=lf
*.csv    text eol=lf

*.py     text eol=lf
*.rb     text eol=lf
*.go     text eol=lf
*.rs     text eol=lf
*.java   text eol=lf
*.c      text eol=lf
*.cpp    text eol=lf
*.h      text eol=lf

*.sql    text eol=lf
*.graphql text eol=lf
*.proto  text eol=lf

*.conf   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf

# Git 自身配置
.gitattributes text eol=lf
.gitignore     text eol=lf
.gitmodules    text eol=lf
.editorconfig  text eol=lf
LICENSE        text eol=lf

# ----------------------------------------
